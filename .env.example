# ML Leakage Detector - Environment Configuration
# ================================================
# Copy this file to .env and fill in your API keys

# NVIDIA NGC API Key (REQUIRED for AI features)
# Get your free key at: https://org.ngc.nvidia.com/
# Sign up → Go to API Key → Generate
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional: AWS Credentials (for cloud deployment)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# Optional: Stripe (for paid features)
# STRIPE_API_KEY=sk_live_xxxxx

# Configuration
MODEL_PREFS=nvidia  # Use 'nvidia' for NVIDIA NIM only (recommended)
DEFAULT_MODEL=nvidia/nemotron-70b-instruct
FALLBACK_MODEL=nvidia/llama-3.1-70b-instruct

# Performance settings
MAX_TOKENS=1500
TEMPERATURE=0.3
